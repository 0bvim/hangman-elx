<h1>The game</h1>
<p>
    Turns left: <%= @tally.turns_left %>
</p>

<p>
    Letters used: <%= @tally.used |> Enum.join(", ") %>
</p>

<p>
    Letters: <%= @tally.letters |> Enum.join(" ") %>
</p>

<.form :let={f} for={%{}} as={:make_move} action={~p"/hangman"} method="put">
  <.input field={f[:guess]} label="Your guess" />

  <.button type="submit">
    Make next guess
  </.button>
</.form>
